{
  "info": {
    "name": "ecom-notification-service",
    "description": "API de notificacoes\n\nBase URL: {{base_url}}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "ecom-notification"
  },
  "item": [
    {
      "name": "Enviar email",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"email\",\n  \"to\": \"cliente@email.com\",\n  \"subject\": \"Pedido Confirmado\",\n  \"body\": \"Seu pedido #12345 foi confirmado com sucesso!\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/notifications/send",
          "host": ["{{base_url}}"],
          "path": ["api", "notifications", "send"]
        }
      }
    },
    {
      "name": "Enviar SMS (stub)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"sms\",\n  \"to\": \"11999999999\",\n  \"body\": \"Seu pedido #12345 foi enviado!\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/notifications/send",
          "host": ["{{base_url}}"],
          "path": ["api", "notifications", "send"]
        }
      }
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:3008", "type": "string" }
  ]
}
